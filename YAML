# Configuración de Conectividad para Soclean (Antigravity + Jules)
version: "1.0"
runtime: nodejs20 # Asegúrate de usar la versión que tengas en tu package.json
service_name: soclean-backend

antigravity:
  cluster_zone: us-central1-a # Ajusta a tu zona de despliegue
  scaling:
    min_instances: 1
    max_instances: 5

jules_agent:
  enabled: true
  entry_point: "npm start"
  env_vars:
    - name: NODE_ENV
      value: "production"
    - name: JULES_API_KEY
      secret: "JULES_SECRET_KEY" # Esto debe estar en Secret Manager

  # Define qué puede hacer Jules en tu proyecto de Node.js
  capabilities:
    - code_analysis
    - dependency_updates
    - automated_testing:
        command: "npm test"

deployment:
  github_repo: "socleanops/App-web-Coordinaci-n-Soclean"
  branch: jules/optimize-supabase-queries-b
